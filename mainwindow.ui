        <property name="styleSheet">
         <string notr="true">/* --- 1. L'IMAGE DE FOND --- */
QWidget#page_employes {
    /* Assure-toi que le chemin de ton image est correct ici ! */
    border-image: url(:/new/prefix1/images/bg_left.jpg) 0 0 0 0 stretch stretch;
}

/* --- 2. LE CADRE FORMULAIRE &amp; STATISTIQUES (Verre Blanc) --- */
QGroupBox {
    /* Fond BLANC avec transparence (Alpha = 210 sur 255 pour lisibilité) */
    background-color: rgba(255, 255, 255, 210); 
    border: 1px solid rgba(0, 0, 0, 20); /* Bordure grise subtile */
    border-radius: 15px;
    margin-top: 25px; 
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 20px;
    color: #2E7D32; /* Vert Foncé EcoCycle pour le contraste sur blanc */
    font-weight: bold;
    font-size: 16px;
    background-color: transparent;
}

/* --- 3. LES LABELS --- */
QLabel {
    color: #333333; /* Texte GRIS FONCÉ/NOIR */
    font-weight: bold;
    font-size: 13px;
    background-color: transparent;
}

/* --- 4. CHAMPS DE SAISIE (Inputs Clairs) --- */
QLineEdit, QComboBox, QDateEdit, QDoubleSpinBox {
    /* Fond blanc cassé semi-transparent */
    background-color: rgba(245, 245, 245, 200); 
    border: 1px solid #BDBDBD; /* Bordure grise */
    border-radius: 5px;
    padding: 8px;
    color: #000000; /* Texte NOIR quand on écrit */
    font-weight: bold;
}

QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
    background-color: #FFFFFF; /* Devient blanc pur au clic */
    border: 2px solid #4CAF50; /* Bordure VERTE */
}

/* Spécifique : La liste de choix de Tri */
QComboBox#cb_tri_option {
    min-width: 80px;
    background-color: rgba(255, 255, 255, 200);
    color: #333;
}

/* --- 5. TABLEAU (Liste Blanche) --- */
QTableView {
    background-color: rgba(255, 255, 255, 200); 
    border: 1px solid rgba(0, 0, 0, 20);
    border-radius: 8px;
    gridline-color: rgba(0, 0, 0, 10); /* Lignes grises très fines */
    color: #000000; /* Texte Noir */
    selection-background-color: rgba(76, 175, 80, 180); /* Vert sélection */
    selection-color: white;
    outline: 0;
}

QHeaderView::section {
    background-color: #2E7D32; /* Entête Vert Foncé */
    color: white;
    padding: 8px;
    border: none;
    font-weight: bold;
}

QTableCornerButton::section {
    background-color: rgba(255, 255, 255, 200);
    border: none;
}

/* --- 6. BOUTONS (Couleurs Vives) --- */
QPushButton {
    border-radius: 8px;
    padding: 10px 15px;
    color: white; /* Texte Blanc sur bouton coloré */
    font-weight: bold;
    font-size: 13px;
    border: 1px solid rgba(0,0,0, 10); /* Légère ombre */
}

/* --- COULEURS DES BOUTONS --- */

/* Ajouter : Vert */
QPushButton#btn_ajouter {
    background-color: #43A047; 
}
QPushButton#btn_ajouter:hover { background-color: #2E7D32; }

/* Modifier : Bleu */
QPushButton#btn_modifier {
    background-color: #1E88E5; 
}
QPushButton#btn_modifier:hover { background-color: #1565C0; }

/* Supprimer : Rouge */
QPushButton#btn_supprimer {
    background-color: #E53935; 
}
QPushButton#btn_supprimer:hover { background-color: #C62828; }

/* PDF : Gris */
QPushButton#btn_pdf {
    background-color: #757575; 
}
QPushButton#btn_pdf:hover { background-color: #424242; }

/* Contrat : Marron */
QPushButton#btn_contrat {
    background-color: #795548;
}
QPushButton#btn_contrat:hover { background-color: #5D4037; }

/* Mailing : Violet */
QPushButton#btn_mailing {
    background-color: #8E24AA;
}
QPushButton#btn_mailing:hover { background-color: #7B1FA2; }

/* TRIER : Jaune/Ambre */
QPushButton#btn_tri {
    background-color: #FFC107;
    color: #333; /* Texte foncé sur jaune */
}
QPushButton#btn_tri:hover { background-color: #FFB300; }

/* --- SCROLLBAR --- */
QScrollBar:vertical {
    border: none;
    background: rgba(0,0,0,10);
    width: 10px;
    border-radius: 5px;
}
QScrollBar::handle:vertical {
    background: rgba(0,0,0,30); /* Poignée grise */
    border-radius: 5px;
}

/* --- TAB WIDGET (ONGLETS) --- */
QTabWidget::pane {
    border: none;
    border-radius: 10px;
    background-color: transparent; /* Fond transparent pour voir l'image principale */
    top: -1px; 
}

QTabBar::tab {
    background-color: rgba(255, 255, 255, 150); /* Onglet inactif */
    border: 1px solid rgba(0,0,0, 10);
    border-bottom: none;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    padding: 8px 20px;
    margin-right: 2px;
    font-weight: bold;
    color: #555;
}

QTabBar::tab:selected {
    background-color: rgba(255, 255, 255, 220); /* Onglet actif plus blanc */
    color: #2E7D32; /* Texte Vert EcoCycle */
    border-top: 3px solid #2E7D32; /* Petite barre verte en haut */
}

QTabBar::tab:hover {
    background-color: rgba(255, 255, 255, 180);
}
</string>
        </property>
