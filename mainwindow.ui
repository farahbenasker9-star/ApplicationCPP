        <property name="styleSheet">
         <string notr="true">QTabWidget::pane {
    border: 1px solid #ccc;
    background-color: transparent;
    border: transparent;
    border-radius: 8px;
    gridline-color: rgba(0, 0, 0, 10); /* Lignes grises tr├¿s fines /
    color: #000000; / Texte Noir /
    selection-background-color: rgba(76, 175, 80, 180); / Vert s├®lection */
    selection-color: white;
    outline: 0;
    top: -1px;
}

QTabWidget::tab-bar {
    left: 0px;
}

QTabBar::tab {
    background: #2d7c4d;
    color: white;
    padding: 8px 20px;
    margin-right: 2px;
    border: 1px solid #2d7c4d;
    border-bottom: none;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    font-weight: bold;
}

QTabBar::tab:selected {
    background: #a8d5ba;
    color: #2d7c4d;
    border: 1px solid #ccc;
    border-bottom: 1px solid white;
}

QTabBar::tab:selected {
    background-color: rgba(255, 255, 255, 220); /* Onglet actif plus blanc */
    color: #2E7D32; /* Texte Vert EcoCycle */
    border-top: 3px solid #2E7D32; /* Petite barre verte en haut */
}

QTabBar::tab:hover {
    background-color: rgba(255, 255, 255, 180);
}</string>
