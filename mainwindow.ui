       <property name="styleSheet">
        <string notr="true">QWidget#page_contrat {
    /* Assure-toi que le chemin de ton image est correct ici ! */
    border-image: url(:/new/prefix1/images/bg_left.jpg) 0 0 0 0 stretch stretch ;
}

/* On rend la zone de contenu INVISIBLE pour voir l'image derri├¿re */
#stackedWidget {
    background: transparent;
}
#page_contrat {
    background: transparent;
}

/* =======================================================
   2. LA BARRE DE NAVIGATION (GAUCHE)
   ======================================================= */

/* On donne une couleur &quot;Verre blanc&quot; ├á ton menu pour qu'il soit assorti */
#frame_navbar {
    background-color: rgba(255, 255, 255, 210); /* Blanc semi-transparent */
    border-right: 2px solid #2E7D32; /* Petite ligne verte ├á droite pour s├®parer */
}

/* Style des boutons du menu (Navigation) */
#frame_navbar QPushButton {
    background-color: transparent;
    color: #333;
    text-align: left;
    padding-left: 20px;
    border: none;
    font-weight: bold;
    font-size: 14px;
}

#frame_navbar QPushButton:hover {
    background-color: #2E7D32; /* Devient vert au survol */
    color: white;
    border-radius: 5px;
}

/* =======================================================
   3. ADAPTATION DU STYLE DE TON CO├ëQUIPIER (FORMULAIRES)
   ======================================================= */

/* Le fond des zones de texte (Inputs) */
QLineEdit, QComboBox, QDateEdit, QDoubleSpinBox, QSpinBox, QTextEdit {
    background-color: white;
    border: 1px solid #BDBDBD;
    border-radius: 5px;
    padding: 5px;
    color: #000000;
    font-weight: bold;
    font-size: 12px;
}

/* Quand on clique dans une case */
QLineEdit:focus, QComboBox:focus, QDateEdit:focus, QSpinBox:focus, QTextEdit:focus {
    background-color: #FFFFFF;
    border: 2px solid #4CAF50; /* Bordure VERTE */
}

/* Am├®lioration des fl├¿ches pour QDateEdit / QSpinBox */
QDateEdit, QSpinBox {
    padding-right: 6px;
}
QDateEdit::up-button, QDateEdit::down-button,
QSpinBox::up-button, QSpinBox::down-button {
    width: 18px;
    height: 18px;
}
QDateEdit::up-arrow, QDateEdit::down-arrow,
QSpinBox::up-arrow, QSpinBox::down-arrow {
    width: 8px;
    height: 8px;
}

/* Les Labels (Textes : &quot;Nom&quot;, &quot;Pr├®nom&quot;...) */
QLabel {
    color: #333333; /* Noir/Gris fonc├® pour bien lire sur le fond */
    font-weight: bold;
    font-size: 12px;
}

/* La zone de droite (Liste/Stats) si c'est un GroupBox ou Frame */
QGroupBox, QFrame#frame_droite {
    background-color: rgba(255, 255, 255, 210); 
    border-radius: 15px;
}

/* =======================================================
   4. LES BOUTONS D'ACTION (BAS)
   ======================================================= */

QPushButton {
    border-radius: 8px;
    padding: 8px;
    color: white;
    font-weight: bold;
}

/* Bouton Ajouter (Vert) */
QPushButton#btn_ajouter { background-color: #43A047; }
QPushButton#btn_ajouter:hover { background-color: #2E7D32; }

/* Bouton Modifier (Bleu) */
QPushButton#btn_modifier { background-color: #1E88E5; }
QPushButton#btn_modifier:hover { background-color: #1565C0; }

/* Bouton Supprimer (Rouge) */
QPushButton#btn_supprimer { background-color: #E53935; }
QPushButton#btn_supprimer:hover { background-color: #C62828; }
</string>
