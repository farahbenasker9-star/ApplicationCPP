  <property name="styleSheet">
   <string notr="true">/* --- 1. LE FOND GÉNÉRAL --- */
QDialog {
    /* Vérifie que ce chemin est bon dans tes ressources ! */
    border-image: url(:/new/prefix1/images/bg_left.jpg) 0 0 0 0 stretch stretch;
}

/* --- 2. LE PANNEAU GAUCHE (Vert Foncé Transparent) --- */
QFrame#frame_left {
    background-color: rgba(20, 60, 30, 210); 
    border-top-left-radius: 15px;
    border-bottom-left-radius: 15px;
}

/* Texte à gauche en BLANC */
QFrame#frame_left QLabel {
    color: #ffffff;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 14px;
}

/* Le titre EcoCycle Staff */
QFrame#frame_left QLabel:first-child {
    font-size: 26px;
    font-weight: bold;
    color: #4CAF50;
}

/* --- 3. LE PANNEAU DROIT (Blanc Transparent) --- */
QFrame#frame_right {
  pour voir l'image */
    border-top-right-radius: 15px;
    border-bottom-right-radius: 15px;
}

/* Texte à droite */
QFrame#frame_right QLabel {
    color: #1B5E20;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 22px; 
    font-weight: bold; 
    qproperty-alignment: AlignCenter;
}

/* --- 4. CHAMPS DE SAISIE --- */
QLineEdit {
    background-color: rgba(255, 255, 255, 180);
    border: 1px solid #cccccc;
    border-radius: 5px;
    padding: 10px;
    font-size: 14px;
    color: #333;
    margin-bottom: 10px; /* Un peu d'espace entre les champs */
}

QLineEdit:focus {
    background-color: #ffffff;
    border: 2px solid #4CAF50;
}

/* --- 5. BOUTON SIGN IN --- */
QPushButton#btn_login {
    background-color: #2E7D32; 
    color: white;
    border-radius: 5px;
    padding: 12px;
    font-size: 15px;
    font-weight: bold;
    border: none;
    margin-top: 10px;
}

QPushButton#btn_login:hover {
    background-color: #1B5E20;
    cursor: pointer;
}

QPushButton#btn_login:pressed {
    background-color: #003300;
}</string>
