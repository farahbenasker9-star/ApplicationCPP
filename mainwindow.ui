          <property name="styleSheet">
           <string notr="true">/* 1. On supprime totalement le cadre (le pane) pour un look aéré */
QTabWidget#tabWidget_sub_hist::pane {
    border: none;
    background-color: #ffffff;
    border-radius: 15px;
    margin-top: 10px; /* Espace entre les boutons et le contenu */
}

/* 2. On rend la barre d'onglets transparente */
QTabWidget#tabWidget_sub_hist QTabBar {
    background-color: transparent;
}

/* 3. Le style des &quot;Capsules&quot; non sélectionnées */
QTabWidget#tabWidget_sub_hist QTabBar::tab {
    background-color: #f8f9fa; /* Gris très clair */
    color: #95a5a6;           /* Texte discret */
    border: 1px solid #e9ecef;
    padding: 6px 20px;
    margin-right: 8px;
    border-radius: 20px;      /* Forme de capsule/pilule */
    font-size: 12px;
    min-width: 70px;
}

/* 4. Effet de survol (Hover) */
QTabWidget#tabWidget_sub_hist QTabBar::tab:hover {
    background-color: #f1f2f6;
    color: #2c3e50;
    border: 1px solid #dcdde1;
}

/* 5. La &quot;Capsule Active&quot; (Style innovant) */
QTabWidget#tabWidget_sub_hist QTabBar::tab:selected {
    background-color: #2e7d32; /* Vert EcoCycle */
    color: #ffffff;           /* Texte blanc */
    font-weight: bold;
    border: none;
    /* On ajoute une petite ombre portée pour l'effet flottant */
    box-shadow: 0 4px 8px rgba(46, 125, 50, 0.3);
}

/* 6. Pour que le contenu à l'intérieur soit propre */
QTextBrowser {
    border: none;
    background-color: #ffffff;
}</string>
