QPushButton#btn_tri:hover { background-color: #FFB300; }

/* --- SCROLLBAR --- */
QScrollBar:vertical {
    border: none;
    background: rgba(0,0,0,10);
    width: 10px;
    border-radius: 5px;
}
QScrollBar::handle:vertical {
    background: rgba(0,0,0,30); /* Poignée grise */
    border-radius: 5px;
}

/* --- TAB WIDGET (ONGLETS) --- */
QTabWidget::pane {
    border: none;
    border-radius: 10px;
    background-color: transparent; /* Fond transparent pour voir l'image principale */
    top: -1px; 
}

QTabBar::tab {
    background-color: rgba(255, 255, 255, 150); /* Onglet inactif */
    border: 1px solid rgba(0,0,0, 10);
    border-bottom: none;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    padding: 8px 20px;
    margin-right: 2px;
    font-weight: bold;
    color: #555;
}

QTabBar::tab:selected {
    background-color: rgba(255, 255, 255, 220); /* Onglet actif plus blanc */
    color: #2E7D32; /* Texte Vert EcoCycle */
    border-top: 3px solid #2E7D32; /* Petite barre verte en haut */
}

QTabBar::tab:hover {
    background-color: rgba(255, 255, 255, 180);
}
</string>
