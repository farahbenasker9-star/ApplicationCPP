  <property name="styleSheet">
   <string notr="true">/* --- GÉNÉRAL --- */
QMainWindow {
    background-color: white; /* Fond général */
}

QLabel {
    font-family: &quot;Segoe UI&quot;, &quot;Verdana&quot;, sans-serif;
}

/* --- PANNEAU GAUCHE (VERT) --- */
#frame_left {
    /* Un dégradé subtil pour faire moins &quot;Paint&quot; */
    background: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:1, stop:0 #1b5e20, stop:1 #2e7d32);
    border-top-left-radius: 15px;
    border-bottom-left-radius: 15px;
}

#frame_left QLabel {
    color: white;
}

/* --- PANNEAU DROIT (BLANC) --- */
#frame_right {
    background-color: white;
    border-top-right-radius: 15px;
    border-bottom-right-radius: 15px;
}

/* --- CHAMPS DE TEXTE (MODERNES) --- */
QLineEdit {
    background-color: #F5F7F9; /* Gris très très clair */
    border: 1px solid #E0E0E0; /* Bordure fine grise */
    border-radius: 8px;        /* Coins arrondis */
    padding-left: 15px;        /* Espace entre le bord gauche et le texte */
    font-size: 14px;
    color: #333;
}

QLineEdit:focus {
    background-color: white;
    border: 2px solid #1b5e20; /* Bordure verte quand on écrit */
}

/* --- BOUTON (SIGN IN) --- */
QPushButton#btn_login {
    background-color: #1b5e20;
    color: white;
    border-radius: 8px;
    font-size: 16px;
    font-weight: bold;
    border: none;
}

QPushButton#btn_login:hover {
    background-color: #2e7d32; /* Un peu plus clair au survol */
    cursor: pointer;
}

QPushButton#btn_login:pressed {
    background-color: #003300;
}

/* --- TITRES --- */
/* Pour cibler spécifiquement le titre &quot;Welcome Back&quot; si tu l'as nommé lbl_titre */
#lbl_titre {
    color: #2c3e50;
    font-weight: bold;
    font-size: 26px;
}

/* --- CHECKBOX --- */
QCheckBox {
    color: #666;
    font-size: 13px;
}
QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 3px;
    border: 1px solid #ccc;
}
QCheckBox::indicator:checked {
    background-color: #1b5e20;
}
/* --- NAVBAR (Cadre Gauche) --- */
QFrame#navbar_container {
    /* Blanc transparent pour voir le fond global derrière */
    background-color: rgba(255, 255, 255, 220);
    border-right: 1px solid rgba(0,0,0, 20);
    min-width: 200px; /* Largeur fixe */
    max-width: 220px;
}

/* --- BOUTONS DE NAVIGATION --- */
QFrame#navbar_container QPushButton {
    background-color: transparent;
    border: none;
    text-align: left; /* Texte À  gauche */
    padding: 15px 20px;
    font-size: 14px;
    font-weight: bold;
    color: #555555;
    border-left: 5px solid transparent; /* Barre verte invisible par défaut */
}

/* Survol des boutons */
QFrame#navbar_container QPushButton:hover, QFrame#navbar_container QPushButton:checked {
    background-color: rgba(46, 125, 50, 30); /* Vert très pÀ¢le */
    color: #2E7D32; /* Texte Vert */
    border-left: 5px solid #2E7D32; /* La barre verte apparaît */
}

/* BOUTON DÉCONNEXION (Spécial) */
QPushButton#btn_logout {
    text-align: center;
    background-color: rgba(211, 47, 47, 30);
    color: #D32F2F;
    border-radius: 5px;
    margin: 20px;
    padding: 10px;
}
QPushButton#btn_logout:hover {
    background-color: #D32F2F;
    color: white;
}</string>
