    background: #4CAF50;
    color: white;
    font-weight: bold;
}

/* Zone de contenu du tab - enlever le contour noir */
QTabWidget::pane {
    border: none;
    background-color: white;
}

charts_placeholder {
    background-color: white;
}</string>
