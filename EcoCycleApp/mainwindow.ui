               <string notr="true">/* Onglet non sélectionné */
QTabBar::tab {
    background: #E0E0E0;
    color: #333;
    padding: 8px 20px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    margin-right: 2px;
    font-weight: bold;
}

/* Onglet sélectionné */
