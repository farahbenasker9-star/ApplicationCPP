        <widget class="QWidget" name="tab_finance">
         <property name="styleSheet">
          <string notr="true">/* --- FOND GLOBAL DE L'ONGLET --- */
QWidget#tab_finance {
    background-color: #f8f9fa; /* Gris très clair pour faire ressortir les cadres blancs */
}

/* --- STYLE GÉNÉRAL DES TEXTES --- */
QLabel {
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    color: #2c3e50;
    background: transparent;
}

/* --- CADRES DES INDICATEURS (KPI) --- */
QFrame#frame_dispo, QFrame#frame_ca {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    border-radius: 6px;
}

/* Barre supérieure verte pour le Capital */
QFrame#frame_dispo {
    border-top: 4px solid #2e7d32;
}

/* Barre supérieure bleue pour le Chiffre d'Affaires */
QFrame#frame_ca {
    border-top: 4px solid #1565c0;
}

/* Titres à l'intérieur des cadres (Capital / Chiffre d'affaires) */
QLabel#label_6, QLabel#label_7, QLabel#lbl_titre_dispo, QLabel#lbl_titre_ca {
    color: #7f8c8d;
    font-size: 11px;
    font-weight: bold;
    text-transform: uppercase;
}

/* Valeurs numériques à l'intérieur des cadres */
QLabel#lbl_val_dispo {
    color: #1b5e20;
    font-size: 20px;
    font-weight: bold;
}

QLabel#lbl_val_ca {
    color: #0d47a1;
    font-size: 20px;
    font-weight: bold;
}

/* --- STYLE DU TABLEAU FINANCIER --- */
/*QTableWidget {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    gridline-color: #f1f2f6;
    alternate-background-color: #fafafa; /* Lignes alternées grises 
    selection-background-color: #e8f5e9;
    selection-color: #2e7d32;
    border-radius: 4px;
}*/

/* En-tête du tableau (Matière, Unités, etc.) */
/*QHeaderView::section {
    background-color: #f1f2f6;
    color: #444444;
    padding: 10px;
    font-weight: bold;
    font-size: 11px;
    border: none;
    border-right: 1px solid #dcdde1;
    border-bottom: 2px solid #dcdde1;
    text-transform: uppercase;
}*/
/* --- STYLE DU TABLEAU (POLICE DIMINUÉE) --- */
QTableWidget {
    background-color: #ffffff;
    border: 1px solid #dcdde1;
    gridline-color: #f1f2f6;
    alternate-background-color: #fcfcfc;
    
    /* ON DIMINUE LA TAILLE ICI */
    font-size: 10px; 
    color: #2c3e50;
    outline: none;
}

/* En-tête du tableau plus compact */
QHeaderView::section {
    background-color: #f8f9fa;
    color: #333333;
    padding: 6px;
    font-weight: bold;
    font-size: 9px; /* En-tête encore plus petit */
    border: none;
    border-right: 1px solid #dcdde1;
    border-bottom: 2px solid #2e7d32;
    text-transform: uppercase;
}

/* Style des cellules sélectionnées */
QTableWidget::item:selected {
    background-color: #e8f5e9;
    color: #2e7d32;
}

/* --- SECTION ALERTES --- */
QFrame#frame_alertes {
    background-color: #fff9db; /* Jaune alerte doux */
    border: 1px solid #ffe066;
    border-radius: 6px;
}

QLabel#label_17, QLabel#lbl_titre_alertes {
    color: #f59f00; /* Orange foncé pour le titre d'alerte */
    font-weight: bold;
    font-size: 12px;
    text-transform: uppercase;
}

QListWidget#list_alertes {
    background-color: transparent;
    border: none;
    font-size: 12px;
    color: #576574;
}
/* --- STYLE DU TITRE DE SECTION --- */
QLabel#lbl_titre_tableau {
    color: #576574;           /* Gris anthracite discret */
    font-size: 10px;          /* Petite taille */
    font-weight: bold;
    text-transform: uppercase; /* Majuscules professionnelles */
    letter-spacing: 1px;      /* Espacement des lettres pour le look &quot;pro&quot; */
    margin-bottom: 5px;
}

</string>
